# =====================================================
# PicoClaw Skills — Environment Variables Reference
# =====================================================
# Save this as ~/.picoclaw/.env.picoclaw (or point PICOCLAW_ENV_FILE to another path).
#
# Your config.json already handles:
#   ✅ OPENAI_API_KEY (in model_list)
#   ✅ TELEGRAM_BOT_TOKEN (in channels.telegram)
#   ✅ TELEGRAM_USER_ID (in channels.telegram.allow_from)
#
# Add the vars below to your Pi environment:
#   Option A: Export in ~/.bashrc or ~/.profile
#   Option B: Add to your systemd service file (EnvironmentFile=)
#   Option C: Export before running `picoclaw gateway`
# =====================================================

# ── Workspace security mode ──────────────────────────
# Set false so git-summary can scan repos outside ~/.picoclaw/workspace
export PICOCLAW_AGENTS_DEFAULTS_RESTRICT_TO_WORKSPACE=false

# ── Timezone ──────────────────────────────────────────
export TZ=Asia/Kolkata

# ── Email Digest skill ────────────────────────────────
# Needed by: skills/email-digest, skills/morning-briefing
# Gmail: Settings > Google Account > Security > App Passwords (requires 2FA)
export EMAIL_IMAP_HOST=imap.gmail.com
export EMAIL_IMAP_PORT=993
export EMAIL_ADDRESS=you@gmail.com
export EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (NOT your login password)

# ── Todoist Manager skill ─────────────────────────────
# Needed by: skills/todoist-manager, skills/morning-briefing
# todoist.com > Settings > Integrations > Developer > API token
export TODOIST_API_TOKEN=xxxx

# ── Google Calendar ───────────────────────────────────
# Needed by: skills/morning-briefing (meetings section)
# Steps:
#   1. console.cloud.google.com > IAM > Service Accounts > Create
#   2. Grant it "Google Calendar API" scope
#   3. Share your calendar with the service account email
#   4. Download JSON key and place on Pi
export GOOGLE_CALENDAR_ID=primary
export GOOGLE_SERVICE_ACCOUNT_JSON=/home/pi/.picoclaw/google-sa.json

# ── Google Maps (Commute Time) ────────────────────────
# Needed by: skills/morning-briefing (commute section)
# Get key: console.cloud.google.com > APIs > Distance Matrix API
# Free tier: 200 USD/month credit (covers typical daily usage)
export GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
# Your home location for commute calculation (city/neighbourhood is enough)
export COMMUTE_HOME_ADDRESS=Velachery, Chennai
# Destination is hardcoded to Hardy Tower, Ramanujan IT Park, Sholinganallur, Chennai

# ── Git Summary skill ─────────────────────────────────
# Needed by: skills/git-summary, skills/morning-briefing
# List local repo paths on the Pi OR GitHub owner/repo refs, comma-separated.
# Examples:
#   Local:  /home/pi/projects/picoclaw
#   GitHub: thisisprabha/time-left
export GIT_REPOS=thisisprabha/time-left,thisisprabha/another-repo

# ── Weather ───────────────────────────────────────────
# Morning briefing uses wttr.in (FREE, no API key needed)
export WEATHER_CITY=Chennai

# ── App Store Connect skill ───────────────────────────
# Needed by: skills/app-store-connect, skills/aso
# Get keys: appstoreconnect.apple.com/access/integrations/api
export ASC_KEY_ID=XXXXXXXXXX
export ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
export ASC_PRIVATE_KEY_PATH=/home/pi/.picoclaw/AuthKey_XXXXXXXXXX.p8
# Your app's numeric ID (from App Store Connect > Apps > App Information)
export ASC_APP_ID=6478XXXXXX

# ── Slack Digest skill ────────────────────────────────
# Needed by: skills/slack-digest
# api.slack.com/apps > Create New App > OAuth & Permissions > Bot Token Scopes: channels:history, channels:read
export SLACK_BOT_TOKEN=xoxb-xxx
export SLACK_CHANNEL_ID=C0XXXXXXX

# ── Optional: Figma ───────────────────────────────────
# figma.com > Settings > Personal Access Tokens
# export FIGMA_ACCESS_TOKEN=xxxx
# export FIGMA_FILE_KEY=xxxx

# ── Optional: Linear ──────────────────────────────────
# linear.app > Settings > API > Personal API Keys
# export LINEAR_API_KEY=lin_api_xxxx
